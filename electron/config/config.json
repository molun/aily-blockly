{
  "lang": "zh_CN",
  "theme": "default",
  "font": "default",
  "appdata_path": {
    "win32": "%HOMEPATH%\\AppData\\Local\\aily-project",
    "linux": "~/.config/aily-project",
    "darwin": "~/Library/aily-project"
  },
  "project_path": "%HOMEPATH%\\Documents\\aily-project",
  "build_flavor": "cn",
  "region": "cn",
  "update_download_strategy": {
    "enabled": true,
    "mirror_region_order": ["eu", "cn"],
    "fallback_on_error": true
  },
  "regions": {
    "cn": {
      "name": "China",
      "official": true,
      "enabled": true,
      "api_server": "https://api.yiyu.pro",
      "web": "https://yiyu.pro",
      "ucenter_web": "https://c.yiyu.pro",
      "tool_web": "https://tool.yiyu.pro",
      "npm_registry": "https://registry.yiyu.pro",
      "resource": "https://blockly.yiyu.pro",
      "updater": "https://dl.yiyu.pro/blockly"
    },
    "eu": {
      "name": "Europe",
      "official": true,
      "enabled": true,
      "api_server": "https://api.aily.pro",
      "web": "https://aily.pro",
      "ucenter_web": "https://c.aily.pro",
      "tool_web": "https://tool.aily.pro",
      "npm_registry": "https://registry.aily.pro",
      "resource": "https://rs1.aily.pro",
      "updater": "https://dl.aily.pro/blockly"
    },
    "localhost": {
      "name": "Local",
      "official": false,
      "enabled": true,
      "api_server": "https://api.yiyu.pro",
      "web": "https://yiyu.pro",
      "ucenter_web": "https://c.yiyu.pro",
      "tool_web": "https://tool.yiyu.pro",
      "npm_registry": "http://localhost:4873",
      "resource": "http://localhost:4874",
      "updater": ""
    }
  },
  "compile": {
    "verbose": true,
    "warnings": "error"
  },
  "upload": {
    "verbose": true,
    "warnings": "error"
  },
  "platform": "win32",
  "devmode": false,
  "blockly": {
    "renderer": "thrasos"
  }
}